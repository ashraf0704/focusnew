{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx server/index.ts",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "web": "vite --port=3000 --host=0.0.0.0",
    "android": "npm --prefix focus-buddy-native run android",
    "build": "vite build",
    "build:native": "npm --prefix focus-buddy-native run build",
    "build:all": "vite build && npm --prefix focus-buddy-native run build",
    "preview": "vite preview",
    "clean": "node -e \"import('node:fs').then(fs=>{fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('server.js',{force:true});})\" ",
    "lint": "tsc --noEmit",
    "test:selenium:web": "tsx tests/web.test.ts",
    "test:selenium:app": "tsx tests/app.test.ts",
    "test:load": "tsx tests/load-test.ts",
    "test:all": "npm run test:selenium:web && npm run test:selenium:app"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@google/genai": "^1.29.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.13",
    "@react-navigation/native-stack": "^7.18.5",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo": "~54.0.0",
    "expo-crypto": "~15.0.9",
    "expo-secure-store": "~15.0.8",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "vite-plugin-pwa": "^1.0.0",
    "web-push": "^3.6.7",
    "workbox-core": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/react": "~19.1.10",
    "@types/selenium-webdriver": "^4.1.23",
    "@types/web-push": "^3.6.4",
    "autocannon": "^7.15.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "selenium-webdriver": "^4.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vite": "^6.2.3"
  }
}
