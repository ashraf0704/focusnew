{
  "expo": {
    "name": "Focus Buddy",
    "slug": "focus-buddy-native",
    "jsEngine": "hermes",
    "scheme": "focusbuddy",
    "version": "0.1.0",
    "icon": "./assets/icons/icon.jpg",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FEFAE0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.focusbuddy.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Focus Buddy uses the camera for the KameraShield focus monitor.",
        "NSMicrophoneUsageDescription": "Focus Buddy uses the microphone for voice input in the AI doubt solver."
      }
    },
    "android": {
      "package": "app.focusbuddy.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#FEFAE0"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-camera",
      "expo-document-picker",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FEFAE0"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7ee7e705-8ed4-4936-b9d7-e4ccc0c900fd"
      }
    },
    "owner": "ashraf07"
  }
}
